<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Foryou Institute | Master English</title>
    <style>
        /* --- CSS STYLES --- */
        :root {
            --primary: #2c3e50;
            --accent: #e67e22;
            --light: #ecf0f1;
            --dark: #34495e;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        body {
            line-height: 1.6;
            color: var(--dark);
            background-color: #f9f9f9;
        }

        /* Navigation */
        nav {
            background: var(--primary);
            color: white;
            padding: 1rem;
            position: fixed;
            width: 100%;
            top: 0;
            z-index: 1000;
            display: flex;
            justify-content: space-around;
            align-items: center;
        }

        nav a {
            color: white;
            text-decoration: none;
            margin: 0 15px;
            font-weight: bold;
        }

        nav a:hover { color: var(--accent); }

        /* Sections General */
        section {
            padding: 100px 20px;
            max-width: 1200px;
            margin: 0 auto;
            text-align: center;
        }

        h2 {
            font-size: 2.5rem;
            margin-bottom: 2rem;
            color: var(--primary);
            border-bottom: 3px solid var(--accent);
            display: inline-block;
        }

        /* Team Section */
        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
        }

        .card {
            background: white;
            padding: 20px;
            border-radius: 10px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        }

        .card img {
            width: 100px;
            height: 100px;
            border-radius: 50%;
            background: #eee;
            margin-bottom: 10px;
        }

        /* Offers Section */
        #offers {
            background: var(--accent);
            color: white;
            border-radius: 20px;
            margin-top: 20px;
        }

        .promo-box {
            font-size: 1.5rem;
            font-weight: bold;
            padding: 20px;
            border: 2px dashed white;
        }

        /* Registration Form */
        form {
            display: flex;
            flex-direction: column;
            max-width: 500px;
            margin: 0 auto;
            background: white;
            padding: 30px;
            border-radius: 10px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        }

        input, select, button {
            margin-bottom: 15px;
            padding: 12px;
            border: 1px solid #ddd;
            border-radius: 5px;
        }

        button {
            background: var(--primary);
            color: white;
            cursor: pointer;
            font-size: 1.1rem;
            transition: 0.3s;
        }

        button:hover { background: var(--accent); }

        /* Feedback Section */
        #feedback-container {
            font-style: italic;
            font-size: 1.2rem;
            background: #fff;
            padding: 40px;
            border-left: 5px solid var(--accent);
        }
    </style>
</head>
<body>

    <nav>
        <h1>Foryou Institute</h1>
        <div>
            <a href="#team">Team</a>
            <a href="#offers">Offers</a>
            <a href="#register">Register</a>
            <a href="#feedback">Reviews</a>
        </div>
    </nav>

    <!-- Header / Hero -->
    <header style="background: linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.6)), url('https://images.unsplash.com/photo-1523050854058-8df90110c9f1?ixlib=rb-1.2.1&auto=format&fit=crop&w=1350&q=80') center/cover; height: 60vh; display: flex; align-items: center; justify-content: center; color: white; margin-top: 60px;">
        <div style="text-align: center;">
            <h1 style="font-size: 3.5rem;">Unlock Your Future</h1>
            <p style="font-size: 1.2rem;">Expert English Training at Foryou Institute</p>
        </div>
    </header>

    <!-- Team Section -->
    <section id="team">
        <h2>Our Leadership & Teachers</h2>
        <div class="grid">
            <div class="card">
                <div style="font-size: 50px;">👨‍💼</div>
                <h3>Dr. Julian Reed</h3>
                <p>Institute Manager</p>
            </div>
            <div class="card">
                <div style="font-size: 50px;">👩‍🏫</div>
                <h3>Sarah Jenkins</h3>
                <p>Head of IELTS Dept.</p>
            </div>
            <div class="card">
                <div style="font-size: 50px;">👨‍🏫</div>
                <h3>Mark Thompson</h3>
                <p>Senior Conversationalist</p>
            </div>
        </div>
    </section>

    <!-- Offers Section -->
    <section id="offers">
        <h2>Special Offers & Discounts</h2>
        <div class="promo-box">
            <p>SUMMER SPECIAL: 25% OFF all Beginners Courses!</p>
            <p style="font-size: 1rem; margin-top: 10px;">Use Code: FORYOU25</p>
        </div>
    </section>

    <!-- Registration Section -->
    <section id="register">
        <h2>Join Us Today</h2>
        <form id="regForm">
            <input type="text" placeholder="Full Name" required>
            <input type="email" placeholder="Email Address" required>
            <select>
                <option value="">Select Level</option>
                <option value="beginner">Beginner</option>
                <option value="intermediate">Intermediate</option>
                <option value="advanced">Advanced (IELTS/TOEFL)</option>
            </select>
            <button type="submit">Submit Registration</button>
        </form>
    </section>

    <!-- Feedback Section -->
    <section id="feedback">
        <h2>Student Feedback</h2>
        <div id="feedback-container">
            <!-- Content loaded by JS -->
            "Loading what our students say..."
        </div>
        <button onclick="displayRandomFeedback()" style="margin-top: 20px; background: none; color: var(--accent); border: 1px solid var(--accent); padding: 5px 15px;">Next Review</button>
    </section>

    <footer style="background: var(--dark); color: white; padding: 20px; text-align: center;">
        <p>&copy; 2024 Foryou Institute. All rights reserved.</p>
    </footer>

    <!-- --- JAVASCRIPT --- -->
    <script>
        const feedbacks = [
            { text: "The teachers at Foryou Institute changed my life. I went from zero to fluent in 6 months!", author: "Ahmed R." },
            { text: "Best IELTS preparation center in the city. Highly recommended!", author: "Maria S." },
            { text: "The atmosphere is so friendly. It's not just a school, it's a community.", author: "Kevin L." },
            { text: "I loved the flexible evening classes. Perfect for working professionals.", author: "Linda W." },
            { text: "Great discounts and really high-quality materials.", author: "John D." }
        ];

        function displayRandomFeedback() {
            const container = document.getElementById('feedback-container');
            const randomIdx = Math.floor(Math.random() * feedbacks.length);
            const item = feedbacks[randomIdx];
            
            container.innerHTML = `
                <p>"${item.text}"</p>
                <p style="margin-top:10px; font-weight:bold; color:var(--accent);">- ${item.author}</p>
            `;
        }

        // Handle Form Submission
        document.getElementById('regForm').addEventListener('submit', function(e) {
            e.preventDefault();
            alert("Thank you for registering at Foryou Institute! We will contact you shortly.");
            this.reset();
        });

        // Initialize first feedback on load
        window.onload = displayRandomFeedback;
    </script>
